# ---- OS ----
.DS_Store
Thumbs.db

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# ---- Node / TypeScript ----
node_modules/
# Compiled extension output — regenerated by `npm run compile` / `vsce package`.
antigravity-voice/out/
*.vsix

# ---- Editor / tooling ----
**/.claude/settings.local.json

# ---- Google Drive shortcut files (meaningless outside Drive) ----
*.gdoc
*.gsheet
*.gslides

# ---- Local runtime state (created at install time, never committed) ----
.levity-voice/
config.json
command.json
*.log

# ---- Secrets ----
# API keys live in the OS keychain (VS Code SecretStorage) or local config,
# never in the repo. This is a safety net.
.env
*.key
