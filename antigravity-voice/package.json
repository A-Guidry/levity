{
  "name": "antigravity-voice",
  "displayName": "Antigravity Voice",
  "description": "Voice-Driven AI Development Service",
  "version": "0.2.0",
  "license": "MIT",
  "author": "Anthony Guidry",
  "repository": {
    "type": "git",
    "url": "https://github.com/A-Guidry/levity"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "antigravity.voice.start",
        "title": "Antigravity: Start/Stop Voice (Walky-Talky)"
      },
      {
        "command": "antigravity.voice.stop",
        "title": "Antigravity: Stop Listening"
      },
      {
        "command": "antigravity.voice.setGeminiKey",
        "title": "Antigravity: Set Gemini API Key"
      },
      {
        "command": "antigravity.voice.setPicovoiceKey",
        "title": "Antigravity: Set Picovoice Access Key"
      },
      {
        "command": "antigravity.voice.openSettings",
        "title": "Antigravity: Open Voice Settings"
      },
      {
        "command": "antigravity.voice.reinstallDeps",
        "title": "Antigravity: Reinstall Voice Dependencies"
      },
      {
        "command": "antigravity.server.start",
        "title": "Antigravity: Start Voice Server"
      },
      {
        "command": "antigravity.server.stop",
        "title": "Antigravity: Stop Voice Server"
      },
      {
        "command": "antigravity.wakeword.toggle",
        "title": "Antigravity: Toggle Wake Word"
      },
      {
        "command": "antigravity.response.toggle",
        "title": "Antigravity: Toggle Voice Response"
      }
    ],
    "keybindings": [
      {
        "command": "antigravity.voice.start",
        "key": "ctrl+alt+v",
        "mac": "cmd+alt+v",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "Antigravity Voice",
      "properties": {
        "antigravity.triggerMode": {
          "type": "string",
          "default": "tap",
          "enum": [
            "tap",
            "wakeWord"
          ],
          "enumDescriptions": [
            "Tap the hotkey to start, tap again (or wait for silence) to stop",
            "Always-on wake-word detection — say the keyword to start"
          ],
          "description": "How to activate voice input."
        },
        "antigravity.wakeWord.keyword": {
          "type": "string",
          "default": "computer",
          "enum": [
            "alexa",
            "americano",
            "blueberry",
            "bumblebee",
            "computer",
            "grapefruit",
            "grasshopper",
            "hey barista",
            "hey google",
            "hey siri",
            "jarvis",
            "ok google",
            "picovoice",
            "porcupine",
            "terminator"
          ],
          "description": "Built-in wake word for hands-free activation. Requires Picovoice access key."
        },
        "antigravity.wakeWord.customKeywordPath": {
          "type": "string",
          "default": "",
          "description": "Path to a custom Porcupine .ppn keyword file (created at console.picovoice.ai). Leave empty to use a built-in keyword."
        },
        "antigravity.tts.preferredTier": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "local",
            "cloud"
          ],
          "enumDescriptions": [
            "Short responses use local macOS voice, longer ones use Gemini TTS",
            "Always use macOS say command (free, offline)",
            "Always use Gemini 2.5 Flash TTS (requires API key)"
          ],
          "description": "Which TTS engine to prefer."
        },
        "antigravity.tts.localVoice": {
          "type": "string",
          "default": "Samantha",
          "description": "macOS voice name for local TTS (e.g. Samantha, Alex, Daniel, Karen). Run 'say -v ?' in Terminal to list available voices."
        },
        "antigravity.tts.geminiVoice": {
          "type": "string",
          "default": "Kore",
          "enum": [
            "Aoede",
            "Charon",
            "Fenrir",
            "Kore",
            "Puck",
            "Leda",
            "Orus",
            "Perseus",
            "Zephyr"
          ],
          "description": "Gemini TTS voice persona."
        },
        "antigravity.tts.localThreshold": {
          "type": "number",
          "default": 200,
          "description": "Character count threshold — responses shorter than this use local TTS in 'auto' mode."
        },
        "antigravity.whisper.model": {
          "type": "string",
          "default": "base",
          "enum": [
            "tiny",
            "base",
            "small",
            "medium"
          ],
          "enumDescriptions": [
            "Fastest, least accurate (~39MB)",
            "Good balance of speed and accuracy (~140MB)",
            "Better accuracy, slower (~460MB)",
            "Best accuracy, slowest (~1.5GB)"
          ],
          "description": "Whisper model size for speech-to-text."
        },
        "antigravity.silenceDuration": {
          "type": "number",
          "default": 10,
          "minimum": 2,
          "maximum": 30,
          "description": "Seconds of silence after speech before auto-finalizing (in tap and wake-word modes)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "setup-sidecar": "cd sidecar && chmod +x setup.sh && ./setup.sh"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.1.3"
  },
  "dependencies": {}
}
